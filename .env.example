# ── Active LLM provider: "vultr" (default) or "crusoe" ───────────────────────
LLM_PROVIDER=vultr

# ── Vultr Serverless Inference (OpenAI-compatible) ────────────────────────────
VULTR_API_KEY=your_vultr_key_here
VULTR_BASE_URL=https://api.vultrinference.com/v1/
VULTR_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# ── Crusoe Managed Inference (optional alternative provider) ──────────────────
CRUSOE_API_KEY=
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/
CRUSOE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── SEC EDGAR requires a User-Agent with contact info ─────────────────────────
EDGAR_USER_AGENT=signal-to-ticket research agent (you@example.com)

# ── Gradium TTS (optional — reads tickets aloud) ──────────────────────────────
GRADIUM_API_KEY=
