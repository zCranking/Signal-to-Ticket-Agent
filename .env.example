# Crusoe Managed Inference
CRUSOE_API_KEY=your_crusoe_api_key_here
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/
CRUSOE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Vultr Serverless Inference (VultronRetriever for embeddings)
VULTR_API_KEY=your_vultr_api_key_here
VULTR_BASE_URL=https://api.vultrinference.com/v1/
VULTR_EMBED_MODEL=vultr/vultronretriever-v1

# Gradium TTS (stretch goal)
GRADIUM_API_KEY=your_gradium_api_key_here
